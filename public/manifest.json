{
  "manifest_version": 3,
  "name": "Klipy Extension",
  "version": "1.0.0",
  "description": "Send Klipy GIFs to Facebook chat",
  "action": {
    "default_title": "Klipy"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "permissions": [
    "tabs",
    "activeTab",
    "sidePanel"
  ],
  "host_permissions": [
    "https://api.klipy.com/*",
    "https://static.klipy.com/*",
    "https://www.facebook.com/*",
    "https://www.messenger.com/*"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.facebook.com/*",
        "https://www.messenger.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}